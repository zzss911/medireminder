# Zs服药提醒智能体 - 环境变量配置
# ⚠️ 复制此文件为 .env 填入真实值，.env 不会被提交到 Git

# ====== 必须配置 ======

# Supabase Service Role Key（服务端管理，去 Supabase Dashboard → Settings → API 获取）
SUPABASE_SERVICE_KEY=your_supabase_service_key

# 千问 API Key（去 https://dashscope.console.aliyun.com/apiKey 申请）
AI_API_KEY=your_dashscope_api_key

# ====== 可选配置 ======

# AI 识别引擎（qianwen / claude / openai / easyocr）
# 默认 qianwen，本地开发环境如有 easyocr 也可用 easyocr
# AI_PROVIDER=qianwen

# 千问模型（qwen-vl-plus 推荐 / qwen-vl-max 精度最高）
# QWEN_MODEL=qwen-vl-plus

# 千问 API 地址（默认阿里云，无需修改）
# QWEN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Supabase 公开信息（默认已配好，无需修改）
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
